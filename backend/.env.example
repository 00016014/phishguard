# Django core
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-strong-random-secret
DJANGO_ALLOWED_HOSTS=api.phishguard.uz,localhost,127.0.0.1

# CORS / CSRF for frontend domains
DJANGO_CORS_ALLOWED_ORIGINS=https://phishguard.uz,https://www.phishguard.uz,http://localhost:4028,http://127.0.0.1:4028
DJANGO_CSRF_TRUSTED_ORIGINS=https://phishguard.uz,https://www.phishguard.uz,http://localhost:4028,http://127.0.0.1:4028

# Secure cookie and TLS behavior
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

# Optional: override static/media roots for cPanel docroot mapping
DJANGO_STATIC_ROOT=
DJANGO_MEDIA_ROOT=

# Email (optional)
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=app-password
DEFAULT_FROM_EMAIL=PhishGuard Security <noreply@phishguard.uz>
FRONTEND_APP_URL=https://phishguard.uz

# OpenAI (optional)
OPENAI_API_KEY=
